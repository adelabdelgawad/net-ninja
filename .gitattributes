# Auto-detect text files and normalize line endings
* text=auto eol=lf

# Explicit text files
*.rs text
*.ts text
*.tsx text
*.js text
*.jsx text
*.json text
*.toml text
*.yaml text
*.yml text
*.md text
*.css text
*.html text
*.sql text

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# Tauri build artifacts
*.msi binary
*.nsis binary
*.AppImage binary
*.deb binary
*.dmg binary
