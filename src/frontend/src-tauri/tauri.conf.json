{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NetNinja",
  "version": "0.1.3",
  "identifier": "com.netninja.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build && cargo build --release --features service --bin netninja-service --manifest-path ../backend/Cargo.toml"
  },
  "app": {
    "windows": [
      {
        "title": "NetNinja",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 768,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ],
    "resources": {
      "../../backend/target/release/netninja-service.exe": "./"
    },
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerIcon": "icons/icon.ico",
        "installerHooks": "nsis/installer-hooks.nsh"
      }
    }
  }
}
